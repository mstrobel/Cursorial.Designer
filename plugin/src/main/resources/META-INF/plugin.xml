<idea-plugin>
    <id>dev.cursorial.designer</id>
    <name>Cursorial Designer</name>
    <vendor url="https://cursorial.dev">Cursorial</vendor>

    <description><![CDATA[
        <p>XAML editor and live visual designer for the
        <a href="https://cursorial.dev">Cursorial</a> terminal UI framework.</p>

        <ul>
            <li><b>Live preview</b> — a split text/preview editor renders your XAML as a real
                character-cell frame through the framework's own headless host: what you see is
                what the terminal draws, including theme, color tier, and terminal capability
                profiles (switchable from the toolbar).</li>
            <li><b>Code completion</b> — elements with contextual filtering, properties and
                attached properties, enum/bool/GridLength values, markup extensions, binding
                paths with source inference, resource keys, style selectors (pseudo-classes,
                style classes, combinators), types, and xmlns-aware prefix narrowing.</li>
            <li><b>Live diagnostics</b> — parse AND build-phase errors as you type, in the
                editor and the Problems view.</li>
            <li><b>Navigation and docs</b> — go-to-definition into your sources (portable PDB
                based), quick documentation from XML doc files, in-document jumps for named
                elements, resource keys, and selector references.</li>
            <li><b>Semantic highlighting</b> — extension arguments, selector paths, binding
                paths, type-aware values, with a dedicated color settings page.</li>
            <li><b>Element inspector</b> — click to select elements in the preview, walk the
                element chain, and inspect property values with full provenance (local, style,
                template, inherited, theme default) plus per-cell composition sampling.</li>
        </ul>

        <p>Requires the <b>.NET 10 SDK</b> (<code>dotnet</code> on the PATH) — the same SDK
        Cursorial app development already needs.</p>
    ]]></description>

    <change-notes><![CDATA[
        <h3>0.1.0</h3>
        <p>Initial release: live character-cell preview with theme/tier/capability switching,
        completion, live parse + build diagnostics, semantic highlighting, quick docs,
        go-to-definition, element inspector with property provenance, and dotnet-new template
        awareness. Matches Cursorial 0.4.0.</p>
    ]]></change-notes>

    <!-- Frontend-only plugin targeting Rider; no ReSharper backend part in this phase. -->
    <depends>com.intellij.modules.rider</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="dev.cursorial.designer.editor.CursorialPreviewEditorProvider" />

        <!-- Cursorial XAML is its own XML-derived language, and marker-matching .xaml files are
             CLAIMED from Rider's XAML file type per file (fileTypeOverrider). Rider routes
             editor actions for its own Xaml language through the R# backend before platform EPs
             run — docs/goto could never fire on .xaml while Rider owned the files. Deriving
             from XML buys the native lexer/PSI: syntax coloring, tag matching, folding,
             structure view. Every non-Cursorial .xaml (WPF, Avalonia, …) is untouched. -->
        <fileType name="Cursorial XAML" language="CursorialXaml" extensions="cxaml" fieldName="INSTANCE"
                  implementationClass="dev.cursorial.designer.language.CursorialXamlFileType" />
        <fileTypeOverrider implementation="dev.cursorial.designer.language.CursorialXamlFileTypeOverrider" />
        <lang.parserDefinition language="CursorialXaml"
                               implementationClass="dev.cursorial.designer.language.CursorialXamlParserDefinition" />
        <standardResourceProvider implementation="dev.cursorial.designer.language.CursorialXamlResourceProvider" />
        <xml.xmlSuppressionProvider implementation="dev.cursorial.designer.language.CursorialXamlSuppressionProvider" />
        <daemon.highlightInfoFilter implementation="dev.cursorial.designer.language.CursorialXamlHighlightFilter" />
        <colorSettingsPage implementation="dev.cursorial.designer.language.CursorialXamlColorSettingsPage" />

        <externalAnnotator language="CursorialXaml"
                           implementationClass="dev.cursorial.designer.language.CursorialXamlExternalAnnotator" />
        <!-- Registered for XML too: PSI LEAVES carry the XML token language (dialect files share
             XML's token types), and caret-language consumers (completion, docs) look up by the
             leaf. Both implementations gate per file, so foreign XML documents are untouched. -->
        <completion.contributor language="XML"
                                implementationClass="dev.cursorial.designer.language.CursorialXamlCompletionContributor" />
        <completion.contributor language="CursorialXaml"
                                implementationClass="dev.cursorial.designer.language.CursorialXamlCompletionContributor" />
        <!-- Tag auto-closing for files without XML PSI (none, since the overrider); the handler
             stands down when the platform's XML typed handlers already serve the file. -->
        <typedHandler implementation="dev.cursorial.designer.language.CursorialXamlTypedHandler" />
        <!-- Quick documentation + go-to-declaration, answered by the language service (XML-doc
             summaries from the assemblies' doc files; source locations from portable PDBs). -->
        <lang.documentationProvider language="CursorialXaml"
                                    implementationClass="dev.cursorial.designer.language.CursorialXamlDocumentationProvider" />
        <lang.documentationProvider language="XML"
                                    implementationClass="dev.cursorial.designer.language.CursorialXamlDocumentationProvider" />
        <gotoDeclarationHandler implementation="dev.cursorial.designer.language.CursorialXamlGotoDeclarationHandler" />
        <!-- Ctrl+W steps through markup-extension structure ({x:Static Type.Member} nesting). -->
        <extendWordSelectionHandler implementation="dev.cursorial.designer.language.CursorialXamlExtendSelectionHandler" />
        <!-- Attribute → property-element form, XAML-correct (attached names verbatim, plain
             properties owner-qualified, directives excluded). The filter hides the foreign
             "convert to nested element" item, which doubles prefixes under our dialect. -->
        <intentionAction>
            <language>CursorialXaml</language>
            <className>dev.cursorial.designer.language.CursorialXamlConvertAttributeIntention</className>
            <category>Cursorial XAML</category>
        </intentionAction>
        <daemon.intentionActionFilter implementation="dev.cursorial.designer.language.CursorialXamlIntentionFilter" />

        <!--
            dev.cursorial.designer.settings.CursorialDesignerSettings is a light service
            (@Service annotation) and needs no registration here.
        -->
    </extensions>
</idea-plugin>
