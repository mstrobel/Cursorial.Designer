<idea-plugin>
    <id>dev.cursorial.designer</id>
    <name>Cursorial Designer</name>
    <vendor url="https://cursorial.dev">Cursorial</vendor>

    <description><![CDATA[
        XAML editor and visual designer for the Cursorial terminal UI framework.
        Adds a split (text + live preview) editor for Cursorial XAML files that renders
        the UI as a character-cell grid via an out-of-process preview host.
    ]]></description>

    <!-- Frontend-only plugin targeting Rider; no ReSharper backend part in this phase. -->
    <depends>com.intellij.modules.rider</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="dev.cursorial.designer.editor.CursorialPreviewEditorProvider" />

        <!-- Editor services for Cursorial XAML (gated per-file to documents carrying the
             cursorial.dev xmlns; every other .xaml file is untouched). -->
        <externalAnnotator language="XML"
                           implementationClass="dev.cursorial.designer.language.CursorialXamlExternalAnnotator" />
        <completion.contributor language="XML"
                                implementationClass="dev.cursorial.designer.language.CursorialXamlCompletionContributor" />

        <!--
            dev.cursorial.designer.settings.CursorialDesignerSettings is a light service
            (@Service annotation) and needs no registration here.
        -->
    </extensions>
</idea-plugin>
