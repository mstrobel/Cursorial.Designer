<idea-plugin>
    <id>dev.cursorial.designer</id>
    <name>Cursorial Designer</name>
    <vendor url="https://cursorial.dev">Cursorial</vendor>

    <description><![CDATA[
        XAML editor and visual designer for the Cursorial terminal UI framework.
        Adds a split (text + live preview) editor for Cursorial XAML files that renders
        the UI as a character-cell grid via an out-of-process preview host.
    ]]></description>

    <!-- Frontend-only plugin targeting Rider; no ReSharper backend part in this phase. -->
    <depends>com.intellij.modules.rider</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="dev.cursorial.designer.editor.CursorialPreviewEditorProvider" />

        <!-- Cursorial XAML is its own XML-derived language, and marker-matching .xaml files are
             CLAIMED from Rider's XAML file type per file (fileTypeOverrider). Rider routes
             editor actions for its own Xaml language through the R# backend before platform EPs
             run — docs/goto could never fire on .xaml while Rider owned the files. Deriving
             from XML buys the native lexer/PSI: syntax coloring, tag matching, folding,
             structure view. Every non-Cursorial .xaml (WPF, Avalonia, …) is untouched. -->
        <fileType name="Cursorial XAML" language="CursorialXaml" extensions="cxaml" fieldName="INSTANCE"
                  implementationClass="dev.cursorial.designer.language.CursorialXamlFileType" />
        <fileTypeOverrider implementation="dev.cursorial.designer.language.CursorialXamlFileTypeOverrider" />

        <externalAnnotator language="CursorialXaml"
                           implementationClass="dev.cursorial.designer.language.CursorialXamlExternalAnnotator" />
        <completion.contributor language="CursorialXaml"
                                implementationClass="dev.cursorial.designer.language.CursorialXamlCompletionContributor" />
        <!-- Tag auto-closing for files without XML PSI (none, since the overrider); the handler
             stands down when the platform's XML typed handlers already serve the file. -->
        <typedHandler implementation="dev.cursorial.designer.language.CursorialXamlTypedHandler" />
        <!-- Quick documentation + go-to-declaration, answered by the language service (XML-doc
             summaries from the assemblies' doc files; source locations from portable PDBs). -->
        <lang.documentationProvider language="CursorialXaml"
                                    implementationClass="dev.cursorial.designer.language.CursorialXamlDocumentationProvider" />
        <gotoDeclarationHandler implementation="dev.cursorial.designer.language.CursorialXamlGotoDeclarationHandler" />
        <!-- Ctrl+W steps through markup-extension structure ({x:Static Type.Member} nesting). -->
        <extendWordSelectionHandler implementation="dev.cursorial.designer.language.CursorialXamlExtendSelectionHandler" />

        <!--
            dev.cursorial.designer.settings.CursorialDesignerSettings is a light service
            (@Service annotation) and needs no registration here.
        -->
    </extensions>
</idea-plugin>
